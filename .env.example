# =========================================================================
# Ng'umbi Riders — environment template
# Copy to .env.local for development. NEVER commit real secrets.
# Anything NOT prefixed with NEXT_PUBLIC_ is server-only and must never be
# imported into a client component.
# =========================================================================

# --- Application ---------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase (public — safe for the browser) ----------------------------
# The publishable/anon key is safe to expose; RLS enforces access.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Supabase (server-only — NEVER expose) -------------------------------
# Service-role key bypasses RLS. Used only by the admin client on the server.
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection string, used by migrations / RLS tests only.
DATABASE_URL=

# --- Rider PIN authentication (server-only) ------------------------------
# 32+ byte high-entropy secret. The four-digit PIN is NEVER stored; the
# Supabase password is derived server-side as
# HMAC_SHA256(AUTH_PIN_PEPPER, canonical_phone + ':' + pin).
AUTH_PIN_PEPPER=

# --- Field-level PII encryption (server-only) ----------------------------
# Base64-encoded 32-byte key for AES-256-GCM encryption of NIDA / licence /
# address / guarantor data. Generate: openssl rand -base64 32
PII_ENCRYPTION_KEY=

# --- Snippe mobile money (server-only) — Phase 5 -------------------------
SNIPPE_API_KEY=
SNIPPE_WEBHOOK_SECRET=
SNIPPE_BASE_URL=

# --- Resend email (server-only) — Phase 8 --------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=
OWNER_SUMMARY_EMAIL=

# --- Mobishastra SMS (server-only) — guarantor + owner notifications ------
# 8-digit profile id (200XXXXX), account password, and an operator-approved
# sender id. SMS stays disabled (messages left pending) until all three are set.
MOBISHASTRA_USER=
MOBISHASTRA_PASSWORD=
MOBISHASTRA_SENDER_ID=
MOBISHASTRA_BASE_URL=
# Owner's phone (E.164, e.g. +2557...) to receive new-request SMS alerts (#6).
OWNER_NOTIFY_PHONE=

# --- Web Push / VAPID (Phase 8) ------------------------------------------
# VAPID_PUBLIC_KEY may be surfaced to the browser at runtime via a server
# endpoint; the private key is server-only.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:owner@ngumbi.co.tz

# --- Scheduled jobs (server-only) ----------------------------------------
# Shared secret required in the Authorization header of every cron endpoint.
CRON_SECRET=

# --- Observability (Phase 10) --------------------------------------------
SENTRY_DSN=

# ---- Script-only variables (never needed by the app itself) ----------------
# scripts/seed.ts — development/demo seeding (override the defaults):
# SEED_OWNER_EMAIL=owner@example.co.tz
# SEED_OWNER_PASSWORD=change-me
# scripts/set-owner-password.ts — rotate the owner login:
# OWNER_NEW_PASSWORD=
# OWNER_PHONE=
# tests/integration/rls — opt-in live RLS isolation suite:
# RLS_TEST_ENABLED=1
